# Environment variables for findpapers database API keys and configurations
# Copy this file to '.env' and fill in your keys.

# Contact email used for polite-pool access (highly recommended for OpenAlex and CrossRef to avoid rate-limiting)
FINDPAPERS_EMAIL=your.email@institution.edu

# API Keys (Optional but highly recommended to access Scopus, IEEE, WoS, or increase rate limits)
FINDPAPERS_IEEE_API_TOKEN=
FINDPAPERS_SCOPUS_API_TOKEN=
FINDPAPERS_PUBMED_API_TOKEN=
FINDPAPERS_OPENALEX_API_TOKEN=
FINDPAPERS_SEMANTIC_SCHOLAR_API_TOKEN=
FINDPAPERS_WOS_API_TOKEN=

# Proxy and network settings (if required behind institutional firewalls)
FINDPAPERS_PROXY=
FINDPAPERS_SSL_VERIFY=true
